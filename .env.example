# Скопируйте в .env и заполните на сервере. Файл .env не коммитить в git.
MODEL_PATH=model_data/best_openvino_model
SMB_SERVER=fs.example.local
SMB_USERNAME=
SMB_PASSWORD=
SMB_DOMAIN=
DETECT_SCORE_THRESHOLD=0.7
DETECT_IMAGE_SIZE=1024
DATASET_AUTOSAVE_ENABLED=false
DATASET_SCORE_THRESHOLD=0.5
SMB_COMPRESS_ENABLED=true
SMB_FIX_EXIF_ORIENTATION=true
SMB_COMPRESS_MAX_SIDE=1024
SMB_COMPRESS_JPEG_QUALITY=50
SMB_SAVE_RESULT_ENABLED=true
REQUEST_PREVIEW_SAVE_ENABLED=false
RUNTIME_SETTINGS_FILE=data/runtime_settings.json
PROJECT_TIMEZONE=Europe/Moscow
EXPORT_ZIP_TTL_HOURS=24
